---
import Layout from '../layouts/Layout.astro';
import DownloadCard from '../components/DownloadCard';
import YoutubeSection from '../components/YoutubeSection';
import '../styles/global.css';
---

<Layout title="My Creative Hub">
  <main class="min-h-screen bg-black text-white px-6 py-20">
    <div class="max-w-4xl mx-auto">
      <header class="mb-12">
        <h1 class="text-6xl font-bold tracking-tighter uppercase text-white">
          Archive 01
        </h1>
      </header>

      <div class="grid gap-12">
        <YoutubeSection client:load videoId="Kwr1VIp4nLw" />
        
        <div class="grid md:grid-cols-2 gap-6">
          <DownloadCard 
            client:load 
            title="Piano MIDI" 
            type="MIDI" 
            description="Download the latest track."
            link="#"
          />
        </div>
      </div>
    </div>
  </main>
</Layout>