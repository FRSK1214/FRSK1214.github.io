---
import Layout from '../layouts/Layout.astro';
import DownloadCard from '../components/DownloadCard';
import YoutubeSection from '../components/YoutubeSection';
import SocialLinks from '../components/SocialLinks'; // これを追加
import '../styles/global.css';
---

<Layout title="My Creative Hub">
  <main class="relative min-h-screen bg-[#050505] text-white px-6 py-20">
    <div class="max-w-4xl mx-auto relative z-10">
      
      <header class="mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="space-y-4">
          <h1 class="text-6xl font-light tracking-tighter uppercase">
            Archive <span class="text-white/30">01</span>
          </h1>
          <p class="text-sm text-white/50 font-mono tracking-widest uppercase italic">
            // Digital Assets & Sound Works
          </p>
        </div>
        
        <div class="pb-2">
          <SocialLinks client:load />
        </div>
      </header>

      ...
    </div>
  </main>
</Layout>